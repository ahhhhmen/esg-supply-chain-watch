#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────
# Pre-commit Hook: CI/CD 工作流质量门禁
# 防止低级的 YAML 语法错误、Tab 缩进、gitignore 冲突等问题
# ─────────────────────────────────────────────────────────
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

errors=0
warnings=0

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🔍 Pre-commit: 工作流质量检查"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── 1. YAML 语法检查 ──────────────────────────────────
echo ""
echo "📋 [1/4] YAML 语法检查..."

for yml_file in .github/workflows/*.yml; do
    [ -f "$yml_file" ] || continue
    if python3 -c "import yaml; yaml.safe_load(open('$yml_file'))" 2>/dev/null; then
        echo "  ${GREEN}✅${NC} $yml_file — 语法正确"
    else
        echo "  ${RED}❌${NC} $yml_file — YAML 语法错误！"
        python3 -c "import yaml; yaml.safe_load(open('$yml_file'))"
        ((errors++))
    fi
done

# ── 2. Tab 字符检测（YAML 禁止 Tab 缩进） ──────────────
echo ""
echo "📋 [2/4] Tab 字符检测（YAML 禁止 Tab）..."

for yml_file in .github/workflows/*.yml; do
    [ -f "$yml_file" ] || continue
    tab_lines=$(grep -n $'\t' "$yml_file" || true)
    if [ -n "$tab_lines" ]; then
        echo "  ${RED}❌${NC} $yml_file — 发现 Tab 字符："
        echo "$tab_lines" | while read line; do
            echo "       $line"
        done
        ((errors++))
    else
        echo "  ${GREEN}✅${NC} $yml_file — 无 Tab 字符"
    fi
done

# ── 3. gitignore 冲突检测 ────────────────────────────
echo ""
echo "📋 [3/4] gitignore 与工作流冲突检测..."

# 从工作流中提取 git add 的目标文件
git_add_targets=$(grep -oh 'git add [^&|;]*' .github/workflows/*.yml 2>/dev/null | \
    sed 's/git add //g' | sed 's/["'\'']//g' | tr ' ' '\n' | sort -u | grep -v '^$' || true)

if [ -n "$git_add_targets" ]; then
    for target in $git_add_targets; do
        # 检查是否被 gitignore
        if git check-ignore -q "$target" 2>/dev/null; then
            echo "  ${RED}❌${NC} 工作流 git add 的目标文件 '$target' 被 .gitignore 忽略！"
            echo "      → 工作流运行时会失败（git add 被拒绝）"
            ((errors++))
        else
            echo "  ${GREEN}✅${NC} '$target' — 未被 gitignore，安全"
        fi
    done
else
    echo "  ${YELLOW}⚠️${NC}  未检测到 git add 命令（可能正常）"
fi

# ── 4. 脚本中 set -e 敏感操作检查 ────────────────────
echo ""
echo "📋 [4/4] Shell 脚本健壮性提示..."

for yml_file in .github/workflows/*.yml; do
    [ -f "$yml_file" ] || continue
    # 检测可能因 set -e 而意外退出的模式
    if grep -q 'git add' "$yml_file" 2>/dev/null; then
        if ! grep -q 'git add.*-f\|git add.*--force' "$yml_file" 2>/dev/null; then
            echo "  ${YELLOW}💡${NC} $yml_file: git add 未使用 -f，请确保目标文件不在 .gitignore 中"
        fi
    fi
done

# ── 结果汇总 ──────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ "$errors" -gt 0 ]; then
    echo " ${RED}❌ 发现 $errors 个错误，提交已阻止${NC}"
    echo ""
    echo " 常见修复方法："
    echo "   • YAML Tab → 替换为空格缩进"
    echo "   • gitignore 冲突 → 从 .gitignore 移除该文件，或使用 git add -f"
    exit 1
else
    echo " ${GREEN}✅ 全部通过 ($warnings 个提示)${NC}"
fi
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
